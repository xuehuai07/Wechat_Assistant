{
  "channel": "weixin_ilink",
  "model": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com/v1",
    "timeout_seconds": 60
  },
  "web": {
    "host": "127.0.0.1",
    "port": 9899,
    "session_secret": "change-me-local-only"
  },
  "agent": {
    "max_context_turns": 20,
    "max_steps": 6,
    "tool_allowlist": []
  },
  "wechat": {
    "base_url": "https://ilinkai.weixin.qq.com",
    "credentials_path": "./runtime/wechat_credentials.json",
    "text_only": true,
    "poll_interval_seconds": 1,
    "long_poll_timeout_seconds": 35
  },
  "storage": {
    "sqlite_path": "./runtime/agent.sqlite3"
  },
  "logging": {
    "path": "./runtime/logs/app.log"
  }
}
